SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated list of allowed CORS origins for the labeling webapp.
# Set to the deployed webapp URL in production. Use "*" only for local dev.
WEBAPP_ORIGINS=http://localhost:5173

AL_STRATEGY=entropy
AL_QUERY_BATCH_SIZE=10
UNCERTAINTY_THRESHOLD=0.75
IPSS_WINDOW_DAYS=30

MODEL_PATH=./models/patient_model.joblib
