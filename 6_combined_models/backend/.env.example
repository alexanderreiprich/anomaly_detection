SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

WEBAPP_ORIGINS=http://localhost:5173

AL_STRATEGY=entropy
AL_QUERY_BATCH_SIZE=10
UNCERTAINTY_THRESHOLD=0.75
IPSS_WINDOW_DAYS=30

# Separate artifact per model — the two models never share a feature set.
UROFLOW_MODEL_PATH=./models/uroflow_model.joblib
BIOMARKER_MODEL_PATH=./models/biomarker_model.joblib
